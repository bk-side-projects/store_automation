rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // "orders" 컬렉션에 대한 규칙
    // 인증된 사용자만 모든 문서에 대해 읽기, 쓰기 작업을 허용합니다.
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // 향후 다른 컬렉션(예: users, products)에 대한 규칙을 여기에 추가할 수 있습니다.

  }
}
